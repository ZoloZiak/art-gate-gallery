---
import Layout from '@/components/layout/Layout.astro';
import { getTranslations, type Language } from '@/lib/translations';
import { GALLERY_INFO } from '@/data/site';

interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = getTranslations(language);
---

<Layout title={t.visit.title} description={`${t.visit.title} — ${GALLERY_INFO.name}`} language={language}>
  <div class="container mx-auto px-4 py-16">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h1 class="text-4xl font-display font-bold tracking-tight mb-8">
          {t.visit.title}
        </h1>

        <div class="space-y-8">
          <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
            <h2 class="mb-4 text-xl font-semibold flex items-center gap-2">
              <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {t.visit.address}
            </h2>
            <address class="not-italic text-muted-foreground leading-relaxed">
              {GALLERY_INFO.address.street}<br />
              {GALLERY_INFO.address.city}, {GALLERY_INFO.address.zip}<br />
              {GALLERY_INFO.address.country}
            </address>
            <a
              href={GALLERY_INFO.address.mapUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-accent hover:underline"
            >
              {t.visit.map} &rarr;
            </a>
          </div>

          <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
            <h2 class="mb-4 text-xl font-semibold flex items-center gap-2">
              <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {t.visit.hours}
            </h2>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-muted-foreground">Monday</div><div class="text-right">Closed</div>
              <div class="text-muted-foreground">Tuesday – Friday</div><div class="text-right">10:00 – 18:00</div>
              <div class="text-muted-foreground">Saturday</div><div class="text-right">10:00 – 16:00</div>
              <div class="text-muted-foreground">Sunday</div><div class="text-right">Closed</div>
            </div>
          </div>

          <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
            <h2 class="mb-4 text-xl font-semibold flex items-center gap-2">
              <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {t.footer.callUs}
            </h2>
            <p class="mb-2">
              <a href={`tel:${GALLERY_INFO.contact.phone}`} class="text-accent hover:underline font-medium">
                {GALLERY_INFO.contact.phone}
              </a>
            </p>
            <p class="text-sm text-muted-foreground">
              {language === 'sk' ? 'Zavolajte nám alebo nám napíšte email.' : 'Call us or send us an email.'}
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl overflow-hidden h-96 lg:h-auto bg-muted shadow-lg">
        <!-- Google Maps placeholder (use iframe in production) -->
        <div class="flex h-full items-center justify-center bg-gradient-to-br from-stone-200 to-stone-300">
          <div class="text-center p-6">
            <svg class="mx-auto h-12 w-12 text-stone-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="text-stone-700 font-medium">
              {GALLERY_INFO.address.street}, {GALLERY_INFO.address.city}
            </p>
            <a
              href={GALLERY_INFO.address.mapUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-2 inline-flex items-center gap-2 text-sm font-medium text-accent hover:underline"
            >
              {t.visit.map} &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
