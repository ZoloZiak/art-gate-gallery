---
import Layout from '@/components/layout/Layout.astro';
import { getTranslations, type Language } from '@/lib/translations';
import Button from '@/components/ui/Button.astro';
import { contactFormSchema, type ContactFormData } from '@/lib/schemas';
import { GALLERY_INFO } from '@/data/site';

interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = getTranslations(language);

// Handle form submission on server (Astro actions) or client
const handleSubmit = async (formData: FormData) => {
  'use client';

  const data = Object.fromEntries(formData.entries()) as unknown as ContactFormData;
  const result = contactFormSchema.safeParse(data);

  if (!result.success) {
    const errors = result.error.flatten().fieldErrors;
    return { success: false, errors };
  }

  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(result.data),
    });

    const json = await res.json();
    if (!res.ok) throw new Error(json.error || 'Failed to send');

    return { success: true };
  } catch (err: any) {
    return { success: false, error: err.message };
  }
};
---

<Layout title={t.contact.title} description="Contact Art Gate Gallery — send us your inquiry" language={language}>
  <div class="container mx-auto px-4 py-16">
    <div class="mx-auto max-w-2xl">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-display font-bold tracking-tight mb-4">
          {t.contact.title}
        </h1>
        <p class="text-lg text-muted-foreground">
          {language === 'sk'
            ? ' Máte otázky? Pošlite nám správu a my sa vám ozveme čoskoro.'
            : ' Have a question? Send us a message and we will get back to you soon.'}
        </p>
      </div>

      <form method="post" class="space-y-6 rounded-2xl border border-border bg-card p-8 shadow-sm" data-contact-form>
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-medium mb-2">
              {t.contact.name} <span class="text-destructive">*</span>
            </label>
            <input
              type="text"
              name="name"
              id="name"
              required
              class="w-full rounded-lg border border-input bg-background px-4 py-3 focus:ring-2 focus:ring-accent focus:border-transparent transition-shadow"
              placeholder={language === 'sk' ? 'Ján Kováč' : 'John Doe'}
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-2">
              {t.contact.email} <span class="text-destructive">*</span>
            </label>
            <input
              type="email"
              name="email"
              id="email"
              required
              class="w-full rounded-lg border border-input bg-background px-4 py-3 focus:ring-2 focus:ring-accent focus:border-transparent transition-shadow"
              placeholder="john@example.com"
            />
          </div>
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium mb-2">
            {t.contact.subject} <span class="text-destructive">*</span>
          </label>
          <input
            type="text"
            name="subject"
            id="subject"
            required
            class="w-full rounded-lg border border-input bg-background px-4 py-3 focus:ring-2 focus:ring-accent focus:border-transparent transition-shadow"
            placeholder={language === 'sk' ? 'Poplatok výstavy' : 'Exhibition inquiry'}
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium mb-2">
            {t.contact.message} <span class="text-destructive">*</span>
          </label>
          <textarea
            name="message"
            id="message"
            rows="5"
            required
            class="w-full rounded-lg border border-input bg-background px-4 py-3 focus:ring-2 focus:ring-accent focus:border-transparent transition-shadow resize-none"
            placeholder={language === 'sk' ? 'Vaša správa...' : 'Your message...'}
          ></textarea>
        </div>

        <div class="flex items-center gap-4">
          <Button variant="cta" size="lg" type="submit" data-contact-submit>
            {t.contact.send}
          </Button>
          <span id="form-status" class="text-sm h-10"></span>
        </div>
      </form>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <div class="rounded-xl bg-muted/30 p-6">
          <h3 class="font-display font-semibold mb-2">{t.footer.emailUs}</h3>
          <a href={`mailto:${GALLERY_INFO.contact.email}`} class="text-accent hover:underline">
            {GALLERY_INFO.contact.email}
          </a>
        </div>
        <div class="rounded-xl bg-muted/30 p-6">
          <h3 class="font-display font-semibold mb-2">{t.footer.callUs}</h3>
          <a href={`tel:${GALLERY_INFO.contact.phone}`} class="text-accent hover:underline">
            {GALLERY_INFO.contact.phone}
          </a>
        </div>
      </div>
    </div>
  </div>

  <script client:load>
    const form = document.querySelector('[data-contact-form]');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = form.querySelector('[data-contact-submit]');
        const statusEl = document.getElementById('form-status');

        submitBtn.disabled = true;
        statusEl.textContent = 'Sending...';
        statusEl.className = 'text-sm text-muted-foreground h-10';

        const formData = new FormData(form);
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            body: JSON.stringify(Object.fromEntries(formData)),
            headers: { 'Content-Type': 'application/json' },
          });

          const json = await res.json();
          if (res.ok) {
            statusEl.textContent = '✓ Message sent successfully!';
            statusEl.className = 'text-sm text-success h-10';
            form.reset();
          } else {
            throw new Error(json.error || 'Failed');
          }
        } catch (err) {
          statusEl.textContent = '✗ Something went wrong. Please try again.';
          statusEl.className = 'text-sm text-destructive h-10';
        } finally {
          submitBtn.disabled = false;
        }
      });
    }
  </script>
</Layout>
