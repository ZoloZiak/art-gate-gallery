---
import { getTranslations, type Language } from '@/lib/translations';
import { GALLERY_INFO, EXHIBITIONS, ARTISTS } from '@/data/site';

interface Props {
  lang: Language;
  rest?: string[];
}

const { lang, rest = [] } = Astro.params;
const t = getTranslations(lang);

// Route maps per language
const skRoutes: Record<string, any> = {
  '': { component: import('../index.astro'), title: 'Art Gate Gallery' },
  'o-nas': { component: import('../about.astro'), title: t.about.title },
  'vystavy': { component: import('../exhibitions.astro'), title: t.exhibitions.current },
  'navstevujeme': { component: import('../visit.astro'), title: t.visit.title },
  'kontakt': { component: import('../contact.astro'), title: t.contact.title },
};

const enRoutes: Record<string, any> = {
  '': { component: import('../index.astro'), title: 'Art Gate Gallery' },
  'about': { component: import('../about.astro'), title: t.about.title },
  'exhibitions': { component: import('../exhibitions.astro'), title: t.exhibitions.current },
  'visit': { component: import('../visit.astro'), title: t.visit.title },
  'contact': { component: import('../contact.astro'), title: t.contact.title },
};

const routes = lang === 'sk' ? skRoutes : enRoutes;
const path = rest.join('/');
const route = routes[path] || routes[''];

// If no route matched, render 404
if (!route) {
  return Astro.redirect(`/${lang}/404`);
}
---

{(await route.component).render({ language: lang })}
