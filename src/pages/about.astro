---
import Layout from '@/components/layout/Layout.astro';
import { getTranslations, type Language } from '@/lib/translations';
import { GALLERY_INFO } from '@/data/site';

interface Props {
  language?: Language;
}

const { language = 'sk' } = Astro.props;
const t = getTranslations(language);
---

<Layout title={t.about.title} description={GALLERY_INFO.description} language={language}>
  <div class="container mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-display font-bold tracking-tight mb-8">
        {t.about.title}
      </h1>

      <div class="prose prose-lg text-muted-foreground mb-12">
        <p class="text-xl leading-relaxed mb-6">
          {GALLERY_INFO.description}
        </p>
        <p>
          {t.about.mission}
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
          <h3 class="font-display font-semibold mb-3 text-lg">
            {language === 'sk' ? 'Umenie' : 'Art'}
          </h3>
          <p class="text-muted-foreground text-sm">
            {language === 'sk'
              ? 'Výstavy súčasného umenia z lokálnych aj medzinárodných umelcov.'
              : 'Exhibitions of contemporary art from local and international artists.'}
          </p>
        </div>
        <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
          <h3 class="font-display font-semibold mb-3 text-lg">
            {language === 'sk' ? 'Komunita' : 'Community'}
          </h3>
          <p class="text-muted-foreground text-sm">
            {language === 'sk'
              ? 'Myšlienková výmena, workshopy a spoločenské akcie pre všetkých.'
              : 'Idea exchange, workshops, and social events for everyone.'}
          </p>
        </div>
          <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
            <h3 class="font-display font-semibold mb-3 text-lg">
              {language === 'sk' ? 'Kultura' : 'Culture'}
            </h3>
          <p class="text-muted-foreground text-sm">
            {language === 'sk'
              ? 'Obohacovanie kultúrneho prostredia regiónu Martin.'
              : 'Enriching the cultural landscape of the Martin region.'}
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
